# Public cPanel app (set in Setup Python App; never commit real values)
AISTAT_DB_PATH=/home/CPANEL_USER/aistat-private/aistat.db
AISTAT_SECURITY_DB_PATH=/home/CPANEL_USER/aistat-private/security.db
AISTAT_TENANTS_DIR=/home/CPANEL_USER/aistat-private/tenants
AISTAT_ALLOWED_HOSTS=aistat.app,www.aistat.app
AISTAT_FORCE_HTTPS=1
AISTAT_SESSION_COOKIE_SECURE=1
AISTAT_ADMIN_USERNAME=admin
# Optional but recommended: adopts the matching OAuth user as the owner.
# AISTAT_ADMIN_EMAIL=you@example.com
AISTAT_PASSWORD_HASH=REPLACE_WITH_WERKZEUG_HASH
AISTAT_SESSION_SECRET=REPLACE_WITH_INDEPENDENT_32_BYTE_SECRET
AISTAT_INGEST_SECRET=REPLACE_WITH_DIFFERENT_32_BYTE_SECRET
# "Connect your Multica" token intake + worker pull channel. Independent
# third secret; without it the host refuses to accept user tokens.
# AISTAT_WORKER_SECRET=REPLACE_WITH_A_THIRD_32_BYTE_SECRET
# Server stored for connections submitted without an explicit URL.
# AISTAT_DEFAULT_SERVER_URL=https://YOUR_MULTICA_SERVER

# Trusted local Multica machine only
# AISTAT_PUBLISH_URL=https://aistat.app/api/ingest/snapshot
# AISTAT_INGEST_SECRET=THE_SAME_INGEST_SECRET_AS_ON_CPANEL
# AISTAT_TENANT_ID=OWNER_USER_ID_RETURNED_BY_AISTAT_MIGRATE
# AISTAT_PUBLISH_INTERVAL_SECONDS=300
# Token handoff worker (python -m aistat.worker_sync --watch):
# AISTAT_WORKER_SYNC_URL=https://aistat.app
# AISTAT_WORKER_SECRET=THE_SAME_WORKER_SECRET_AS_ON_CPANEL
# Key must stay outside the store's directory (both remain local-only):
# AISTAT_WORKER_KEY_PATH=~/.config/aistat/worker.key
# AISTAT_WORKER_STORE_PATH=/path/to/data/worker_connections.db
# AISTAT_WORKER_PULL_INTERVAL_SECONDS=300

# Optional OAuth login (generic authorization-code flow; a provider is pure
# config, so Yandex is added the same way). List enabled providers, then set
# the per-provider block. Leave unset to keep password-only login.
# AISTAT_OAUTH_PROVIDERS=google
# AISTAT_OAUTH_GOOGLE_AUTHORIZE_URL=https://accounts.google.com/o/oauth2/v2/auth
# AISTAT_OAUTH_GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
# AISTAT_OAUTH_GOOGLE_USERINFO_URL=https://openidconnect.googleapis.com/v1/userinfo
# AISTAT_OAUTH_GOOGLE_SCOPES=openid email profile
# AISTAT_OAUTH_GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
# AISTAT_OAUTH_GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
# AISTAT_OAUTH_GOOGLE_REDIRECT_URI=https://aistat.app/auth/google/callback
# Fail-closed: only these emails may see private data after an OAuth login.
# AISTAT_OAUTH_ALLOWED_EMAILS=you@example.com
